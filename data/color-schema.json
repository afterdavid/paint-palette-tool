{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Paint Palette Tool Color Record",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "manufacturer",
    "brand",
    "brandCode",
    "libraryType",
    "rgbHex",
    "lab",
    "source"
  ],
  "properties": {
    "id": { "type": "string" },
    "displayName": { "type": "string" },
    "manufacturer": { "type": "string" },
    "brand": { "type": "string" },
    "brandCode": { "type": "string" },
    "libraryType": {
      "type": "string",
      "enum": ["native", "universal", "competitor", "derived"]
    },
    "rgbHex": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "lab": {
      "type": "object",
      "required": ["l", "a", "b"],
      "properties": {
        "l": { "type": "number" },
        "a": { "type": "number" },
        "b": { "type": "number" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["official", "manual", "reference", "derived"]
        },
        "url": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "stockMatchable": { "type": "boolean" },
    "lrv": { "type": ["number", "null"] },
    "availabilityNotes": { "type": ["string", "null"] },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "catalogOrder": { "type": ["number", "integer", "null"] },
    "active": { "type": ["boolean", "null"] },
    "sourceConfidence": {
      "type": ["string", "null"],
      "enum": ["high", "medium", "low", null]
    },
    "lastVerifiedAt": { "type": ["string", "null"] },
    "regions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
